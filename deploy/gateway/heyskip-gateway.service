[Unit]
Description=Hey Skip Gateway (clawdbot)
After=network.target

[Service]
Type=simple
User=admin
ExecStart=/usr/bin/env clawdbot gateway run --bind loopback --port 18789 --force
Restart=unless-stopped
RestartSec=5
Environment=NODE_ENV=production
Environment=NODE_OPTIONS=--max-old-space-size=1536

[Install]
WantedBy=multi-user.target
