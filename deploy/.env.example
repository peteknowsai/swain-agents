# Swain deploy environment
# Copy to .env and fill in values

# Convex HTTP actions base URL (Phase 3)
SWAIN_API_URL=https://your-convex-deployment.convex.site

# Agent provisioning API (for advisor creation)
SWAIN_AGENT_API_URL=https://agents.heyswain.com

# API token for swain CLI auth
SWAIN_API_TOKEN=sk_your_token_here

# API token for agent provisioning
SWAIN_AGENT_API_TOKEN=sk_your_agent_token_here
