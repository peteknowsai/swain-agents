      "notes": "Top-level orchestrator. Wakes on Pete's messages."
    },
    {
      "id": "mr-content",
      "agent": "mr-content",
      "type": "editor",
      "runtime": "sprite",
      "alwaysOn": false,
      "notes": "Content operations. Wakes for daily sweeps and dispatches."
    },
    {
      "id": "stylist",
      "agent": "stylist",
      "type": "system",
      "runtime": "sprite",
      "alwaysOn": false,
      "notes": "Card styling. Wakes after beat reporters create cards."
    },
    {
