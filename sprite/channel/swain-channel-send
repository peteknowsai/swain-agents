#!/bin/bash
# Drop a message into the channel inbox for the Agent SDK to pick up.
# Usage: swain-channel-send "message text" "chat_id" [user] [messageId] [type]
#
# Called via: sprite exec -s <name> -- swain-channel-send "hello" "im:+1234"
# The Agent SDK runs as a sprite service and auto-starts on wake.

INBOX_DIR="/home/sprite/.channel/inbox"
mkdir -p "$INBOX_DIR"

TEXT="$1"
CHAT_ID="${2:-default}"
USER="${3:-}"
MESSAGE_ID="${4:-}"
TYPE="${5:-}"

# Timestamp-based filename for ordering
FILENAME="$(date +%s%N).json"

# Use jq for proper JSON encoding — handles quotes, newlines, special chars
jq -n \
  --arg text "$TEXT" \
  --arg chatId "$CHAT_ID" \
  --arg user "$USER" \
  --arg messageId "$MESSAGE_ID" \
  --arg type "$TYPE" \
  --argjson ts "$(date +%s%3N)" \
  '{text: $text, chatId: $chatId, user: $user, messageId: $messageId, type: $type, ts: $ts}' \
  > "$INBOX_DIR/$FILENAME"

# Ensure the agent service is running — it exits after idle timeout,
# so new messages need to kick it back to life.
if ! pgrep -f 'bun run channel/swain-agent.ts' > /dev/null 2>&1; then
  sprite-env services restart channel > /dev/null 2>&1 &
fi

echo "ok"
